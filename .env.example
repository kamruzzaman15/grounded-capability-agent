# Copy to .env and adjust. Defaults assume a local Ollama install.
OLLAMA_BASE_URL=http://localhost:11434

# Generator and reviewer should be DIFFERENT families so the reviewer's
# entailment judgment is independent of the writer. Pick by JSON reliability,
# not benchmark rank. See README "Models".
GENERATOR_MODEL=qwen2.5:14b
REVIEWER_MODEL=gemma3:4b
